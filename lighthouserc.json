{
  "ci": {
    "collect": {
      "url": [
        "https://accessiscan.piposlab.com/",
        "https://accessiscan.piposlab.com/pricing",
        "https://accessiscan.piposlab.com/login",
        "https://accessiscan.piposlab.com/signup",
        "https://accessiscan.piposlab.com/forgot-password",
        "https://accessiscan.piposlab.com/why-not-overlays",
        "https://accessiscan.piposlab.com/overlay-detector"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "throttlingMethod": "simulate"
      }
    },
    "assert": {
      "preset": "lighthouse:no-pwa",
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.75 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.95 }],
        "csp-xss": "off",
        "uses-rel-preconnect": "off",
        "unused-javascript": "off",
        "uses-responsive-images": "off",
        "valid-source-maps": "off",
        "errors-in-console": "off",
        "is-on-https": "off",
        "legacy-javascript": "off",
        "legacy-javascript-insight": "off",
        "critical-request-chains": "off",
        "network-dependency-tree-insight": "off",
        "render-blocking-insight": "off",
        "dom-size-insight": "off",
        "dom-size": "off",
        "third-party-summary": "off",
        "third-parties-insight": "off",
        "forced-reflow-insight": "off",
        "duplicated-javascript-insight": "off",
        "bf-cache": "off",
        "uses-long-cache-ttl": "off",
        "uses-text-compression": "off"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
